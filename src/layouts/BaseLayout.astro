---
// src/layouts/BaseLayout.astro
// Contrato: recibe title opcional, renderiza HTML shell
import "../styles/global.css";
import type { Locale } from "../i18n";

export interface Props {
  title?: string;
  locale?: Locale;
}
const { title = "Rosetta Café", locale = "es" } = Astro.props;
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
