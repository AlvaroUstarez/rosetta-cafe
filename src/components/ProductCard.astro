---
import { categoryGradients } from "../data/category-visual";
import type { Product } from "../data/menu";
import type { Locale } from "../i18n";
import { tRecord } from "../i18n";

export interface Props {
  product: Product;
  locale: Locale;
}

const { product, locale } = Astro.props;
const name = tRecord(product.name, locale);
const description = tRecord(product.description, locale);
const gradient = categoryGradients[product.category];
---

<div class="product-card">
  {
    product.image ? (
      <>
        <img
          class="product-card__image"
          src={product.image}
          alt={name}
          loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
        />
        <div
          class="product-card__image product-card__image--fallback"
          style={`background: ${gradient}`}
          role="img"
          aria-label={name}
        />
      </>
    ) : (
      <div
        class="product-card__image"
        style={`background: ${gradient}`}
        role="img"
        aria-label={name}
      />
    )
  }
  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <p class="product-card__description">{description}</p>
    <span class="product-card__price">$ {product.price}</span>
  </div>
</div>

<style>
  .product-card {
    background: var(--color-surface);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .product-card__image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .product-card__image--fallback {
    display: none;
  }

  .product-card__body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-card__name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-primary);
    margin: 0 0 0.375rem;
  }

  .product-card__description {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.5;
    margin: 0 0 0.75rem;
    flex: 1;
  }

  .product-card__price {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-secondary);
  }
</style>
